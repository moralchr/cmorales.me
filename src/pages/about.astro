---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Chris Morales — software engineer in Orlando, FL.">
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-[680px] mx-auto">
      <span class="label">About</span>
      <h1 class="font-display text-4xl sm:text-5xl mt-4 mb-10">
        A bit about me
      </h1>

      <div class="space-y-6 text-ink-muted leading-relaxed">
        <p>
          I'm a software engineer based in Orlando, Florida. I build internal tools,
          data systems, and automations at a commercial drywall and finishes contractor.
        </p>

        <p>
          My day-to-day involves React and TypeScript apps on Microsoft's Power Platform,
          Dataverse integrations, Power Automate flows, and whatever else needs building
          to keep a construction company running smoothly.
        </p>

        <p>
          Before this role I was [your background here — replace with your actual story].
        </p>

        <p>
          Outside of work, [your interests — replace with what you actually do].
        </p>
      </div>

      <div class="mt-16 pt-8 border-t border-rule">
        <span class="label">Get in touch</span>
        <div class="mt-4 space-y-2">
          <p>
            <a href="mailto:chris@cmorales.me" class="text-accent hover:text-accent-hover transition-colors">
              chris@cmorales.me
            </a>
          </p>
          <p>
            <a
              href="https://github.com/moralchr"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-hover transition-colors"
            >
              github.com/moralchr
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
