---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="Page not found.">
  <section class="min-h-[70vh] flex flex-col items-center justify-center px-6 text-center">
    <span class="label">Sheet CM-404</span>
    <h1 class="text-3xl sm:text-4xl mt-4 mb-6">Not in this set</h1>
    <p class="text-ink-muted mb-8">The page you're looking for doesn't exist.</p>
    <a href="/" class="text-sm text-accent hover:text-accent-hover transition-colors">
      ← Back home
    </a>
  </section>
</BaseLayout>
