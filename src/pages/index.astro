---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const tools = [
  'TypeScript', 'React', 'Node.js', 'Power Platform', 'Dataverse',
  'Power Automate', 'Power BI', 'Azure', 'QuickBooks', 'DocuSign', 'AI Builder',
];

const screens = [
  { id: 'intro', name: 'Intro' },
  { id: 'projects', name: 'Projects' },
  { id: 'background', name: 'Background' },
];

const background = [
  {
    period: '2025 —',
    place: 'Annapurna Construction',
    role: 'Software / Systems Developer',
    bullets: [
      'Dataverse schema migration of 39K+ records across legacy and new tables',
      'QuickBooks Online, QuickBooks Time, and DocuSign integrations',
      'Two internal workspace apps built with React, TypeScript, and Power Apps Code Apps',
      'GitHub monorepo architecture with shared components and CI',
      'Role-based access control across Entra groups, Dataverse roles, and app permissions',
    ],
  },
  {
    period: '2021 — 2025',
    place: 'KPMG US',
    role: 'Senior PMO Analyst',
    bullets: [
      'Managed $15M+ in budgets for state government accounts',
      'Automated Excel reporting with Alteryx, saving hundreds of hours of manual effort',
      '$239K+ in cost savings through resource optimization',
      'Facilitated cross-functional project meetings and trained junior staff',
    ],
  },
  {
    period: '2017 — 2021',
    place: 'Westgate Resorts',
    role: 'Administrative Assistant',
    bullets: [
      'Operational analytics with Excel, SQL, and Tableau',
      'Streamlined reporting, documentation, and training programs',
    ],
  },
];
---

<BaseLayout title="Home">
  <div class="deck-viewport">
    <div class="deck" id="deck">
      <!-- Screen 1: intro -->
      <section class="deck-screen" id="intro">
        <div class="hero-glow top-[-20%] right-[-15%]"></div>
        <div class="w-full max-w-[1100px] mx-auto px-6 relative">
          <p class="hero-fade label" style="--d: 0.05s">Orlando, FL</p>
          <h1 class="mt-4 text-[clamp(2.75rem,7vw,5.5rem)] leading-[1.02] tracking-tight">
            <span class="hero-mask"><span class="hero-line" style="--d: 0.15s">Chris Morales</span></span>
          </h1>
          <p class="hero-fade mt-3 text-lg sm:text-xl text-accent font-medium" style="--d: 0.3s">
            Business Systems Developer
          </p>
          <p class="hero-fade mt-6 max-w-[520px] text-ink-muted leading-relaxed" style="--d: 0.45s">
            I build internal software for a commercial construction company:
            office apps, field tools, and the integrations between them.
          </p>
          <div class="hero-fade mt-6 flex flex-wrap gap-2 max-w-[560px]" style="--d: 0.55s">
            {tools.map(t => <span class="pill">{t}</span>)}
          </div>
          <div class="hero-fade mt-8 flex flex-wrap items-center gap-7" style="--d: 0.65s">
            <a href="mailto:chrismorales5112@gmail.com" class="link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors">Email</a>
            <a href="https://www.linkedin.com/in/cmorales88/" target="_blank" rel="noopener noreferrer" class="link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors">LinkedIn</a>
            <a href="/resume" class="link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors">Resume</a>
            <button
              data-theme-toggle
              type="button"
              aria-label="Toggle dark mode"
              class="text-ink-muted hover:text-ink transition-colors cursor-pointer"
            >
              <svg class="dark:hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4.5" />
                <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8" />
              </svg>
              <svg class="hidden dark:block" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
              </svg>
            </button>
          </div>
        </div>
      </section>

      <!-- Screen 2: projects (horizontal slides) -->
      <section class="deck-screen" id="projects">
        <div class="slides" id="slides">
          {projects.map(project => (
            <article class="slide" id={project.id}>
              <div class="w-full max-w-[1100px] mx-auto grid md:grid-cols-[1.1fr_1fr] gap-8 md:gap-12 items-center">
                <div class="min-w-0">
                  {project.data.kicker && (
                    <span class="label text-accent text-[0.65rem]">{project.data.kicker}</span>
                  )}
                  <h2 class="mt-2 text-[clamp(1.5rem,3.5vw,2.5rem)]">{project.data.title}</h2>
                  <p class="mt-3 text-sm sm:text-base text-ink-muted leading-relaxed">
                    {project.data.description}
                  </p>
                  {project.data.highlights && (
                    <ul class="mt-5 space-y-2">
                      {project.data.highlights.map(h => (
                        <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                          <span class="text-accent shrink-0 mt-0.5">—</span>
                          {h}
                        </li>
                      ))}
                    </ul>
                  )}
                  {project.data.tech && (
                    <div class="mt-5 flex flex-wrap gap-2">
                      {project.data.tech.map(t => <span class="pill">{t}</span>)}
                    </div>
                  )}
                </div>
                <div class="slide-media hidden md:block">
                  {project.data.images && project.data.images.length > 0 ? (
                    <img src={project.data.images[0].src} alt={project.data.images[0].alt} loading="lazy" />
                  ) : (
                    <div class="photo-frame"><span>Photo coming soon</span></div>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="slide-nav">
          <button type="button" class="slide-arrow" id="slide-prev" aria-label="Previous project">←</button>
          <span class="label" id="slide-counter">01 / {String(projects.length).padStart(2, '0')}</span>
          <button type="button" class="slide-arrow" id="slide-next" aria-label="Next project">→</button>
        </div>
      </section>

      <!-- Screen 3: background (accordion — one entry open at a time
           so the screen never overflows) -->
      <section class="deck-screen" id="background">
        <div class="w-full max-w-[1100px] mx-auto px-6">
          <span class="label">Background</span>
          <div class="mt-6 max-w-[720px]" id="background-list">
            {background.map(b => (
              <details class="disclosure group border-b border-rule">
                <summary class="grid sm:grid-cols-[150px_1fr_auto] gap-x-8 gap-y-1 py-4 items-start">
                  <span class="font-mono text-xs text-ink-faint pt-1.5">{b.period}</span>
                  <div>
                    <h2 class="text-lg sm:text-xl group-hover:text-accent transition-colors">{b.place}</h2>
                    <p class="mt-0.5 text-sm text-ink-muted">{b.role}</p>
                  </div>
                  <span class="disc-icon mt-2 text-ink-muted hidden sm:block"></span>
                </summary>
                <div class="disclosure-body pb-5 sm:pl-[calc(150px+2rem)]">
                  <ul class="space-y-1.5">
                    {b.bullets.map(item => (
                      <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                        <span class="text-accent shrink-0 mt-0.5">—</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            ))}

            <details class="disclosure group border-b border-rule">
              <summary class="grid sm:grid-cols-[150px_1fr_auto] gap-x-8 gap-y-1 py-4 items-start">
                <span class="font-mono text-xs text-ink-faint pt-1.5"></span>
                <h2 class="text-lg sm:text-xl group-hover:text-accent transition-colors">About me</h2>
                <span class="disc-icon mt-2 text-ink-muted hidden sm:block"></span>
              </summary>
              <div class="disclosure-body pb-5 sm:pl-[calc(150px+2rem)]">
                <!-- TODO(chris): add anything personal you want here —
                     hobbies, interests, what you're into outside work. -->
                <p class="text-ink-muted text-sm leading-relaxed max-w-[480px]">
                  I came to software from operations, not a CS degree. At KPMG
                  I started automating my own reporting work, and building
                  tools became the job. Based in Orlando.
                </p>
              </div>
            </details>
          </div>

          <p class="mt-6 text-sm text-ink-muted">
            Microsoft Certified: Power Platform Developer (PL-400) ·
            A.A. Information Technology, Valencia College
          </p>
          <p class="mt-10 text-ink-faint text-xs">&copy; {new Date().getFullYear()} Chris Morales</p>
        </div>
      </section>
    </div>

    <nav class="deck-dots" aria-label="Sections">
      {screens.map((s, i) => (
        <button type="button" class="deck-dot" data-goto={i} aria-label={s.name} aria-current={i === 0 ? 'true' : undefined}></button>
      ))}
    </nav>
  </div>

  <script>
    const deck = document.getElementById('deck')!;
    const screens = Array.from(deck.querySelectorAll<HTMLElement>('.deck-screen'));
    const slidesEl = document.getElementById('slides')!;
    const slideCount = slidesEl.children.length;
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.deck-dot'));
    const counter = document.getElementById('slide-counter')!;
    const prevBtn = document.getElementById('slide-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('slide-next') as HTMLButtonElement;
    const projectsIdx = screens.findIndex(s => s.id === 'projects');

    let screenIdx = 0;
    let slideIdx = 0;

    function render() {
      deck.style.transform = `translateY(-${screenIdx * 100}%)`;
      slidesEl.style.transform = `translateX(-${slideIdx * 100}%)`;
      dots.forEach((d, i) =>
        i === screenIdx ? d.setAttribute('aria-current', 'true') : d.removeAttribute('aria-current')
      );
      counter.textContent = `${String(slideIdx + 1).padStart(2, '0')} / ${String(slideCount).padStart(2, '0')}`;
      prevBtn.disabled = slideIdx === 0;
      nextBtn.disabled = slideIdx === slideCount - 1;
      const hash = screenIdx === 0 ? '' : `#${screens[screenIdx].id}`;
      history.replaceState(null, '', hash || location.pathname);
    }

    function goScreen(next: number) {
      screenIdx = Math.min(Math.max(next, 0), screens.length - 1);
      render();
    }

    function goSlide(next: number) {
      slideIdx = Math.min(Math.max(next, 0), slideCount - 1);
      render();
    }

    // Advance: inside the projects screen, horizontal slides consume
    // the gesture until they run out, then the deck moves on.
    function advance(dir: 1 | -1) {
      if (screenIdx === projectsIdx) {
        if (dir > 0 && slideIdx < slideCount - 1) return goSlide(slideIdx + 1);
        if (dir < 0 && slideIdx > 0) return goSlide(slideIdx - 1);
      }
      goScreen(screenIdx + dir);
    }

    // Wheel: accumulate small deltas, lock during the transition so
    // trackpad inertia doesn't skip screens.
    let acc = 0;
    let locked = false;
    window.addEventListener(
      'wheel',
      e => {
        e.preventDefault();
        if (locked) return;
        acc += e.deltaY;
        if (Math.abs(acc) < 30) return;
        const dir = acc > 0 ? 1 : -1;
        acc = 0;
        locked = true;
        advance(dir);
        setTimeout(() => (locked = false), 700);
      },
      { passive: false }
    );

    // Touch: horizontal swipe moves slides on the projects screen,
    // vertical swipe moves screens.
    let tx = 0, ty = 0;
    window.addEventListener('touchstart', e => {
      tx = e.touches[0].clientX;
      ty = e.touches[0].clientY;
    }, { passive: true });
    window.addEventListener('touchmove', e => {
      if (e.touches.length === 1) e.preventDefault(); // keep pinch-zoom working
    }, { passive: false });
    window.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - tx;
      const dy = e.changedTouches[0].clientY - ty;
      if (Math.abs(dx) < 50 && Math.abs(dy) < 50) return;
      if (screenIdx === projectsIdx && Math.abs(dx) > Math.abs(dy)) {
        goSlide(slideIdx + (dx < 0 ? 1 : -1));
      } else {
        advance(dy < 0 ? 1 : -1);
      }
    }, { passive: true });

    // Keyboard (skip when focus is on an interactive element).
    window.addEventListener('keydown', e => {
      if ((e.target as HTMLElement).closest('button, a, input, textarea, select, summary')) return;
      if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') { e.preventDefault(); advance(1); }
      else if (e.key === 'ArrowUp' || e.key === 'PageUp') { e.preventDefault(); advance(-1); }
      else if (e.key === 'ArrowRight' && screenIdx === projectsIdx) goSlide(slideIdx + 1);
      else if (e.key === 'ArrowLeft' && screenIdx === projectsIdx) goSlide(slideIdx - 1);
      else if (e.key === 'Home') goScreen(0);
      else if (e.key === 'End') goScreen(screens.length - 1);
    });

    prevBtn.addEventListener('click', () => goSlide(slideIdx - 1));
    nextBtn.addEventListener('click', () => goSlide(slideIdx + 1));
    dots.forEach(d => d.addEventListener('click', () => goScreen(Number(d.dataset.goto))));

    // Deep links: /#projects, /#background, /#<project-id>.
    function jumpToHash(hash: string) {
      const id = decodeURIComponent(hash.replace('#', ''));
      if (!id) return goScreen(0);
      const screenTarget = screens.findIndex(s => s.id === id);
      if (screenTarget >= 0) return goScreen(screenTarget);
      const slideTarget = Array.from(slidesEl.children).findIndex(el => el.id === id);
      if (slideTarget >= 0) {
        slideIdx = slideTarget;
        goScreen(projectsIdx);
      }
    }

    // Background accordion: one entry open at a time, so the screen
    // height stays bounded (the deck never scrolls vertically).
    const bgList = document.getElementById('background-list')!;
    bgList.addEventListener('toggle', e => {
      const opened = e.target as HTMLDetailsElement;
      if (!opened.open) return;
      bgList.querySelectorAll<HTMLDetailsElement>('details[open]').forEach(d => {
        if (d !== opened) d.open = false;
      });
    }, true);

    if (location.hash) jumpToHash(location.hash);
    render();
  </script>
</BaseLayout>
