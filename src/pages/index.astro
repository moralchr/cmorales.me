---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => data.featured))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout title="Home">
  <section class="min-h-[85vh] flex flex-col justify-center px-6">
    <div class="max-w-[1200px] mx-auto w-full">
      <h1 class="font-display text-[clamp(3.5rem,8vw,7rem)] leading-[0.95] tracking-tight">
        Chris<br />Morales
      </h1>
      <p class="mt-8 max-w-[480px] text-ink-muted text-lg leading-relaxed">
        Software engineer building internal tools and systems
        at a construction company in Orlando.
      </p>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="px-6 pb-24">
      <div class="max-w-[1200px] mx-auto">
        <span class="label">Selected Work</span>
        <div class="mt-8">
          {projects.map((project, i) => (
            <div class:list={['py-8', i > 0 && 'border-t border-rule']}>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
                <h2 class="font-display text-2xl sm:text-3xl">
                  <a
                    href={`/projects#${project.id}`}
                    class="text-ink hover:text-accent transition-colors"
                  >
                    {project.data.title}
                  </a>
                </h2>
                <span class="text-ink-faint text-sm font-mono shrink-0">
                  {project.data.date.getFullYear()}–
                </span>
              </div>
              <p class="mt-3 text-ink-muted max-w-[600px]">{project.data.description}</p>
              {project.data.tech && (
                <div class="flex flex-wrap gap-x-4 gap-y-1 mt-4">
                  {project.data.tech.map(t => (
                    <span class="text-xs font-mono text-ink-faint">{t}</span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
        <a
          href="/projects"
          class="inline-block mt-8 text-sm text-accent hover:text-accent-hover transition-colors"
        >
          View all projects →
        </a>
      </div>
    </section>
  )}

  {posts.length > 0 && (
    <section class="px-6 pb-24">
      <div class="max-w-[1200px] mx-auto">
        <span class="label">Recent Writing</span>
        <div class="mt-8">
          {posts.map((post, i) => (
            <a
              href={`/writing/${post.id}`}
              class:list={[
                'block py-6 text-ink hover:text-accent transition-colors group',
                i > 0 && 'border-t border-rule',
              ]}
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <h3 class="font-display text-xl sm:text-2xl group-hover:text-accent transition-colors">
                  {post.data.title}
                </h3>
                <span class="text-ink-faint text-sm font-mono shrink-0">
                  {post.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    year: 'numeric',
                  })}
                </span>
              </div>
              <p class="mt-2 text-ink-muted text-sm max-w-[600px]">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
        <a
          href="/writing"
          class="inline-block mt-8 text-sm text-accent hover:text-accent-hover transition-colors"
        >
          Read all posts →
        </a>
      </div>
    </section>
  )}
</BaseLayout>
