---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const featured = (await getCollection('projects', ({ data }) => data.featured))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const experience = [
  {
    company: 'Annapurna Construction',
    role: 'Software/Systems Developer',
    period: '2025 — Now',
    summary:
      'Building the internal platform for a commercial construction company — project management and field apps, accounting integrations, and the data architecture underneath.',
    bullets: [
      'Led a Dataverse schema migration of 39K+ records across legacy and new tables — resolving duplicate data and scaling limits while preserving every relationship',
      'Integrated QuickBooks Online, QuickBooks Time, and DocuSign to eliminate duplicate entry and create a single financial source of truth',
      'Co-built two internal workspace applications with React, TypeScript, and Power Apps Code Apps, modernizing office-to-field workflows',
      'Implemented the GitHub-based monorepo architecture: shared components, CI quality gates, documentation and governance standards',
      'Designed role-based access control spanning Entra security groups, MDM, Dataverse security roles, and app-level permissions',
    ],
    hasProjects: true,
  },
  {
    company: 'KPMG US',
    role: 'Senior PMO Analyst',
    period: '2021 — 2025',
    summary:
      'Program financials and reporting automation for state-government consulting engagements.',
    bullets: [
      'Managed $15M+ in engagement budgets under margin pressure, contract ceilings, and compliance requirements',
      'Automated month-end reporting pipelines with Alteryx, saving hundreds of hours of manual PMO effort',
      'Delivered $239K+ in cost savings through resource optimization across engagements',
      'Facilitated cross-functional project meetings and trained junior staff',
    ],
    hasProjects: false,
  },
  {
    company: 'Westgate Resorts',
    role: 'Administrative Assistant',
    period: '2017 — 2021',
    summary: 'Operational analytics and reporting for resort operations.',
    bullets: [
      'Produced operational analytics with Excel, SQL, and Tableau to improve productivity and leadership visibility',
      'Streamlined reporting processes and strengthened documentation and training programs',
    ],
    hasProjects: false,
  },
];

const stack = [
  'React', 'TypeScript', 'Power Platform', 'Dataverse', 'Azure Functions',
  'Power Automate', 'Alteryx', 'Node.js', 'QuickBooks API', 'DocuSign API',
  'Microsoft Graph', 'SQL', 'Power BI', 'Tableau', 'Vite',
];
---

<BaseLayout title="Home">
  <section class="relative min-h-screen flex flex-col justify-center px-6 overflow-hidden">
    <div class="hero-glow top-[-10%] right-[-10%]" data-parallax="0.25"></div>
    <span class="vert-label hidden lg:block">Business Systems Developer — Orlando, FL</span>
    <div class="max-w-[1200px] mx-auto w-full relative">
      <p class="hero-fade label flex items-center gap-2.5" style="--d: 0.05s">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-60"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        Building at Annapurna Construction
      </p>
      <h1 class="mt-6 font-display text-[clamp(4rem,11vw,9.5rem)] leading-[0.92] tracking-tight">
        <span class="hero-mask"><span class="hero-line" style="--d: 0.15s">Chris</span></span>
        <span class="hero-mask"><span class="hero-line italic text-accent" style="--d: 0.28s">Morales</span></span>
      </h1>
      <div class="mt-10 grid sm:grid-cols-[1fr_auto] gap-8 items-end">
        <p class="hero-fade max-w-[480px] text-ink-muted text-lg leading-relaxed" style="--d: 0.5s">
          I build the systems that run a construction company —
          the apps in the office, the tools on the jobsite, and the
          integrations holding the books together.
        </p>
        <div class="hero-fade flex gap-7" style="--d: 0.65s">
          <a
            href="https://www.linkedin.com/in/cmorales88/"
            target="_blank"
            rel="noopener noreferrer"
            class="magnetic link-underline text-sm font-medium text-ink-muted hover:text-ink transition-colors"
          >
            LinkedIn
          </a>
          <a
            href="mailto:chrismorales5112@gmail.com"
            class="magnetic link-underline text-sm font-medium text-ink-muted hover:text-ink transition-colors"
          >
            Email
          </a>
        </div>
      </div>
    </div>
    <div class="hero-fade absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3" style="--d: 1.1s">
      <span class="label text-[0.65rem]">Scroll</span>
      <span class="scroll-cue-line"></span>
    </div>
  </section>

  <section class="px-6 pt-24 pb-16">
    <div class="max-w-[1200px] mx-auto">
      <div class="section-head" data-reveal>
        <span class="section-num">(01)</span>
        <h2 class="font-display text-3xl sm:text-4xl">Experience</h2>
      </div>

      <div class="mt-2">
        {experience.map((job, i) => (
          <details class:list={['disclosure group', i > 0 && 'border-t border-rule']} data-reveal>
            <summary class="py-8 flex items-start gap-6">
              <span class="work-index pt-1.5 hidden sm:block">{String(i + 1).padStart(2, '0')}</span>
              <div class="flex-1">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                  <h3 class="font-display text-2xl sm:text-3xl group-hover:text-accent transition-colors">
                    {job.company}
                  </h3>
                  <span class="text-ink-faint text-sm font-mono shrink-0">{job.period}</span>
                </div>
                <p class="mt-1 text-ink text-sm font-medium">{job.role}</p>
                <p class="mt-2 text-ink-muted text-sm max-w-[560px]">{job.summary}</p>
              </div>
              <span class="disc-icon mt-2 text-ink-muted"></span>
            </summary>
            <div class="disclosure-body pb-10 sm:pl-[calc(3rem+0.5rem)] sm:-mt-2">
              <ul class="space-y-2.5 max-w-[640px]">
                {job.bullets.map(b => (
                  <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                    <span class="text-accent shrink-0 mt-0.5">—</span>
                    {b}
                  </li>
                ))}
              </ul>
              {job.hasProjects && featured.length > 0 && (
                <div class="mt-8">
                  <span class="label">Selected systems</span>
                  <div class="flex flex-wrap gap-x-6 gap-y-2 mt-3">
                    {featured.map(p => (
                      <a
                        href={`/projects#${p.id}`}
                        class="arrow-link text-sm text-accent hover:text-accent-hover transition-colors"
                      >
                        {p.data.title} <span class="arrow">→</span>
                      </a>
                    ))}
                    <a href="/projects" class="arrow-link text-sm text-ink-muted hover:text-ink transition-colors">
                      All projects <span class="arrow">→</span>
                    </a>
                  </div>
                </div>
              )}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12" data-reveal>
    <div class="marquee-wrap border-y border-rule py-5">
      <div class="marquee gap-12 pr-12">
        {[...stack, ...stack].map(item => (
          <span class="text-sm font-mono text-ink-faint whitespace-nowrap">{item}</span>
        ))}
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="px-6 py-16">
      <div class="max-w-[1200px] mx-auto">
        <div class="section-head" data-reveal>
          <span class="section-num">(02)</span>
          <h2 class="font-display text-3xl sm:text-4xl">Writing</h2>
        </div>
        <div class="mt-2">
          {posts.map((post, i) => (
            <a
              href={`/writing/${post.id}`}
              class:list={[
                'arrow-link group flex items-baseline justify-between gap-4 py-5',
                i > 0 && 'border-t border-rule',
              ]}
              data-reveal
            >
              <h3 class="font-display text-lg sm:text-xl text-ink group-hover:text-accent transition-colors">
                {post.data.title} <span class="arrow inline-block text-ink-faint group-hover:text-accent">→</span>
              </h3>
              <span class="text-ink-faint text-sm font-mono shrink-0">
                {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
            </a>
          ))}
        </div>
        <a
          href="/writing"
          class="arrow-link inline-block mt-8 text-sm text-accent hover:text-accent-hover transition-colors"
          data-reveal
        >
          Read all posts <span class="arrow">→</span>
        </a>
      </div>
    </section>
  )}
</BaseLayout>
