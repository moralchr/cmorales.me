---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const systems = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const experience = [
  {
    company: 'Annapurna Construction',
    role: 'Software/Systems Developer',
    period: '2025 — Now',
    summary:
      'Building the internal platform for a commercial construction company — project management and field apps, accounting integrations, and the data architecture underneath.',
    bullets: [
      'Led a Dataverse schema migration of 39K+ records across legacy and new tables — resolving duplicate data and scaling limits while preserving every relationship',
      'Integrated QuickBooks Online, QuickBooks Time, and DocuSign to eliminate duplicate entry and create a single financial source of truth',
      'Co-built two internal workspace applications with React, TypeScript, and Power Apps Code Apps, modernizing office-to-field workflows',
      'Implemented the GitHub-based monorepo architecture: shared components, CI quality gates, documentation and governance standards',
      'Designed role-based access control spanning Entra security groups, MDM, Dataverse security roles, and app-level permissions',
    ],
  },
  {
    company: 'KPMG US',
    role: 'Senior PMO Analyst',
    period: '2021 — 2025',
    summary:
      'Program financials and reporting automation for state-government consulting engagements.',
    bullets: [
      'Managed $15M+ in engagement budgets under margin pressure, contract ceilings, and compliance requirements',
      'Automated month-end reporting pipelines with Alteryx, saving hundreds of hours of manual PMO effort',
      'Delivered $239K+ in cost savings through resource optimization across engagements',
      'Facilitated cross-functional project meetings and trained junior staff',
    ],
  },
  {
    company: 'Westgate Resorts',
    role: 'Administrative Assistant',
    period: '2017 — 2021',
    summary: 'Operational analytics and reporting for resort operations.',
    bullets: [
      'Produced operational analytics with Excel, SQL, and Tableau to improve productivity and leadership visibility',
      'Streamlined reporting processes and strengthened documentation and training programs',
    ],
  },
];
---

<BaseLayout title="Home">
  <!-- Cover sheet: who + what, then straight to the work. -->
  <section class="px-6 pt-32 pb-12">
    <div class="max-w-[1200px] mx-auto">
      <div
        class="hero-fade flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 pb-4 border-b border-ink"
        style="--d: 0.05s"
      >
        <span class="label text-ink">Chris Morales — Business Systems Developer</span>
        <span class="label">Orlando, FL</span>
      </div>

      <h1 class="hero-fade mt-9 max-w-[1020px] text-[clamp(1.85rem,4.4vw,3.4rem)] leading-[1.12] tracking-[-0.02em] font-medium" style="--d: 0.15s">
        I build the software that runs a construction company —
        <span class="text-ink-muted">the apps in the office, the tools on the
        jobsite, and the integrations holding the books together.</span>
      </h1>

      <div
        class="hero-fade mt-8 flex flex-wrap items-baseline justify-between gap-x-8 gap-y-3"
        style="--d: 0.3s"
      >
        <p class="label">Now — internal platform, Annapurna Construction</p>
        <div class="flex gap-6">
          <a
            href="mailto:chrismorales5112@gmail.com"
            class="label link-underline text-ink"
          >
            Email
          </a>
          <a
            href="https://www.linkedin.com/in/cmorales88/"
            target="_blank"
            rel="noopener noreferrer"
            class="label link-underline text-ink"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sheet index: every system, one glance, no clicks. -->
  <section class="px-6 pb-20">
    <div class="max-w-[1200px] mx-auto">
      <div class="section-head hero-fade" style="--d: 0.45s">
        <h2 class="label text-ink">Index of systems</h2>
        <span class="label">{String(systems.length).padStart(2, '0')} sheets</span>
      </div>

      <div>
        {systems.map((p, i) => (
          <a
            href={`/projects#${p.id}`}
            class="index-row group grid grid-cols-[2rem_1fr] sm:grid-cols-[3.5rem_1fr_auto] gap-x-2 py-5 border-b border-rule"
            data-reveal
          >
            <span class="index-no pt-1">{String(i + 1).padStart(2, '0')}</span>
            <div class="min-w-0">
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-0.5">
                <h3 class="text-lg sm:text-xl font-medium tracking-tight group-hover:text-accent transition-colors">
                  {p.data.title}
                </h3>
                {p.data.kicker && (
                  <span class="label text-[0.62rem] hidden sm:inline">{p.data.kicker}</span>
                )}
              </div>
              <p class="mt-1.5 text-sm text-ink-muted leading-relaxed max-w-[680px]">
                {p.data.description}
              </p>
            </div>
            <span class="hidden sm:block font-mono text-xs text-ink-faint pt-1.5">
              {p.data.date.getUTCFullYear()}–
            </span>
          </a>
        ))}
      </div>

      <a
        href="/projects"
        class="arrow-link inline-block mt-6 text-sm font-medium text-ink-muted hover:text-ink transition-colors"
        data-reveal
      >
        Full write-ups, screenshots, and the gnarly parts <span class="arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Experience: on record, one line each, open for the bullets. -->
  <section class="px-6 pb-20">
    <div class="max-w-[1200px] mx-auto">
      <div class="section-head" data-reveal>
        <h2 class="label text-ink">Experience</h2>
        <span class="label">2017 —</span>
      </div>

      <div>
        {experience.map(job => (
          <details class="disclosure group border-b border-rule" data-reveal>
            <summary class="py-5 flex items-baseline gap-4">
              <div class="flex-1 min-w-0 flex flex-col sm:flex-row sm:items-baseline sm:gap-3">
                <h3 class="text-base font-medium tracking-tight group-hover:text-accent transition-colors">
                  {job.company}
                </h3>
                <span class="text-sm text-ink-muted">{job.role}</span>
              </div>
              <span class="font-mono text-xs text-ink-faint shrink-0">{job.period}</span>
              <span class="disc-icon self-center text-ink-muted"></span>
            </summary>
            <div class="disclosure-body pb-8 max-w-[720px]">
              <p class="text-sm text-ink-muted">{job.summary}</p>
              <ul class="mt-4 space-y-2.5">
                {job.bullets.map(b => (
                  <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                    <span class="text-accent shrink-0 mt-0.5">—</span>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="px-6 pb-8">
      <div class="max-w-[1200px] mx-auto">
        <div class="section-head" data-reveal>
          <h2 class="label text-ink">Field notes</h2>
          <a href="/writing" class="label link-underline text-ink">All posts</a>
        </div>
        <div>
          {posts.map(post => (
            <a
              href={`/writing/${post.id}`}
              class="group flex items-baseline justify-between gap-4 py-4 border-b border-rule"
              data-reveal
            >
              <h3 class="text-base font-medium tracking-tight text-ink group-hover:text-accent transition-colors">
                {post.data.title}
              </h3>
              <span class="text-ink-faint text-xs font-mono shrink-0">
                {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
