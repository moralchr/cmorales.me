---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const tools = [
  'TypeScript', 'React', 'Node.js', 'Power Platform', 'Dataverse',
  'Power Automate', 'Power BI', 'Azure', 'QuickBooks',
  'AI Builder', 'MCP',
];

const screens = [
  { id: 'intro', name: 'Intro' },
  { id: 'projects', name: 'Projects' },
  { id: 'background', name: 'Background' },
];

const background = [
  {
    period: '2025 to Present',
    place: 'Annapurna Construction',
    role: 'Software / Systems Developer',
    bullets: [
      'Dataverse schema migration of 39K+ records across legacy and new tables',
      'QuickBooks Online, QuickBooks Time, and DocuSign integrations',
      'Two internal workspace apps built with React, TypeScript, and Power Apps Code Apps',
      'GitHub monorepo architecture with shared components and CI',
      'Role-based access control across Entra groups, Dataverse roles, and app permissions',
    ],
  },
  {
    period: '2021 to 2025',
    place: 'KPMG US',
    role: 'Senior PMO Analyst',
    bullets: [
      'Managed $15M+ in budgets for state government accounts',
      'Automated Excel reporting with Alteryx, saving hundreds of hours of manual effort',
      '$239K+ in cost savings through resource optimization',
      'Facilitated cross-functional project meetings and trained junior staff',
    ],
  },
  {
    period: '2017 to 2021',
    place: 'Westgate Resorts',
    role: 'Administrative Assistant',
    bullets: [
      'Operational analytics with Excel, SQL, and Tableau',
      'Streamlined reporting, documentation, and training programs',
    ],
  },
];
---

<BaseLayout title="Home">
  <div class="deck-viewport">
    <div class="deck" id="deck">
      <!-- Screen 1: intro -->
      <section class="deck-screen" id="intro">
        <div class="hero-glow top-[-20%] right-[-15%]"></div>
        <div class="w-full max-w-[1100px] mx-auto px-6 relative">
          <p class="hero-fade label" style="--d: 0.05s">Orlando, FL</p>
          <h1 class="mt-4 text-[clamp(2.75rem,7vw,5.5rem)] leading-[1.02] tracking-tight">
            <span class="hero-mask"><span class="hero-line" style="--d: 0.15s">Chris Morales</span></span>
          </h1>
          <p class="hero-fade mt-3 text-lg sm:text-xl text-accent font-medium" style="--d: 0.3s">
            Business Systems Developer
          </p>
          <p class="hero-fade mt-6 max-w-[520px] text-ink-muted leading-relaxed" style="--d: 0.45s">
            I build internal software for a commercial construction company:
            office apps, field tools, and the integrations between them.
          </p>
          <div class="hero-fade mt-6 flex flex-wrap gap-2 max-w-[560px]" style="--d: 0.55s">
            {tools.map(t => <span class="pill">{t}</span>)}
          </div>
          <div class="hero-fade mt-8 flex flex-wrap items-center gap-7" style="--d: 0.65s">
            <a href="mailto:chrismorales5112@gmail.com" class="inline-flex items-center gap-2 link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m2 7 10 7L22 7" />
              </svg>
              Email
            </a>
            <a href="https://www.linkedin.com/in/cmorales88/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors">
              <svg width="14" height="14" viewBox="0 0 382 382" fill="currentColor" aria-hidden="true">
                <path d="M347.445,0H34.555C15.471,0,0,15.471,0,34.555v312.889C0,366.529,15.471,382,34.555,382h312.889 C366.529,382,382,366.529,382,347.444V34.555C382,15.471,366.529,0,347.445,0z M118.207,329.844c0,5.554-4.502,10.056-10.056,10.056 H65.345c-5.554,0-10.056-4.502-10.056-10.056V150.403c0-5.554,4.502-10.056,10.056-10.056h42.806 c5.554,0,10.056,4.502,10.056,10.056V329.844z M86.748,123.432c-22.459,0-40.666-18.207-40.666-40.666S64.289,42.1,86.748,42.1 s40.666,18.207,40.666,40.666S109.208,123.432,86.748,123.432z M341.91,330.654c0,5.106-4.14,9.246-9.246,9.246H286.73 c-5.106,0-9.246-4.14-9.246-9.246v-84.168c0-12.556,3.683-55.021-32.813-55.021c-28.309,0-34.051,29.066-35.204,42.11v97.079 c0,5.106-4.139,9.246-9.246,9.246h-44.426c-5.106,0-9.246-4.14-9.246-9.246V149.593c0-5.106,4.14-9.246,9.246-9.246h44.426 c5.106,0,9.246,4.14,9.246,9.246v15.655c10.497-15.753,26.097-27.912,59.312-27.912c73.552,0,73.131,68.716,73.131,106.472 L341.91,330.654L341.91,330.654z" />
              </svg>
              LinkedIn
            </a>
            <a href="/resume" class="inline-flex items-center gap-2 link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v12" />
                <path d="m7 10 5 5 5-5" />
                <path d="M4 21h16" />
              </svg>
              Resume
            </a>
            <button
              data-theme-toggle
              type="button"
              aria-label="Toggle dark mode"
              class="text-ink-muted hover:text-ink transition-colors cursor-pointer"
            >
              <svg class="dark:hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4.5" />
                <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8" />
              </svg>
              <svg class="hidden dark:block" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
              </svg>
            </button>
          </div>
        </div>
      </section>

      <!-- Screen 2: projects (horizontal slides) -->
      <section class="deck-screen" id="projects">
        <div class="slides" id="slides">
          {projects.map(project => (
            <article class="slide" id={project.id}>
              <div class="w-full max-w-[1100px] mx-auto grid md:grid-cols-[1fr_1.2fr] gap-8 md:gap-12 items-center">
                <div class="min-w-0">
                  {project.data.kicker && (
                    <span class="label text-accent text-[0.65rem]">{project.data.kicker}</span>
                  )}
                  <h2 class="mt-2 text-[clamp(1.5rem,3.5vw,2.5rem)]">{project.data.title}</h2>
                  <p class="mt-3 text-sm sm:text-base text-ink-muted leading-relaxed">
                    {project.data.description}
                  </p>
                  {project.data.highlights && (
                    <ul class="mt-5 space-y-2">
                      {project.data.highlights.map(h => (
                        <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                          <span class="text-accent shrink-0 mt-0.5">·</span>
                          {h}
                        </li>
                      ))}
                    </ul>
                  )}
                  {project.data.tech && (
                    <div class="mt-5 flex flex-wrap gap-2">
                      {project.data.tech.map(t => <span class="pill">{t}</span>)}
                    </div>
                  )}
                  {(project.data.beforeAfter || project.data.collage || (project.data.images && project.data.images.length > 0)) && (
                    <button type="button" class="slide-gallery-btn label md:hidden mt-5 text-accent">
                      View screenshots →
                    </button>
                  )}
                </div>
                <div class="slide-media hidden md:block">
                  {project.data.beforeAfter && project.data.beforeAfter.length > 0 ? (
                    <div class={`ba-cycler${project.data.beforeAfter.length === 1 ? ' ba-cycler-single' : ''}`}>
                      <figure class="ba-item">
                        <span class="label ba-label">Before</span>
                        <div class="ba-stack ba-stack-before">
                          {project.data.beforeAfter.map(p => (
                            <img class="ba-card" src={p.before.src} alt={p.before.alt} data-caption="Before" loading="eager" />
                          ))}
                        </div>
                      </figure>
                      {project.data.beforeAfter.length > 1 && (
                        <div class="ba-controls" role="group" aria-label="Cycle before and after comparisons">
                          <button type="button" class="slide-arrow ba-prev" aria-label="Previous comparison">←</button>
                          <span class="label ba-count">1 / {project.data.beforeAfter.length}</span>
                          <button type="button" class="slide-arrow ba-next" aria-label="Next comparison">→</button>
                        </div>
                      )}
                      <figure class="ba-item">
                        <span class="label ba-label">After</span>
                        <div class="ba-stack ba-stack-after">
                          {project.data.beforeAfter.map(p => (
                            <img class="ba-card" src={p.after.src} alt={p.after.alt} data-caption="After" loading="eager" />
                          ))}
                        </div>
                      </figure>
                    </div>
                  ) : project.data.collage && project.data.collage.length > 0 ? (
                    <div class="pm-collage">
                      <div class="pm-collage-top">
                        <img src={project.data.collage[0].src} alt={project.data.collage[0].alt} loading="eager" />
                      </div>
                      {project.data.collage.length > 1 && (
                        <div class="pm-collage-bottom">
                          {project.data.collage.slice(1).map(c => (
                            <img src={c.src} alt={c.alt} loading="eager" />
                          ))}
                        </div>
                      )}
                    </div>
                  ) : project.data.images && project.data.images.length > 1 ? (
                    <div class="img-stack">
                      {project.data.images.map(im => (
                        <img src={im.src} alt={im.alt} data-caption={im.caption} loading="eager" />
                      ))}
                    </div>
                  ) : project.data.images && project.data.images.length > 0 ? (
                    <img src={project.data.images[0].src} alt={project.data.images[0].alt} data-caption={project.data.images[0].caption} loading="eager" />
                  ) : (
                    <div class="photo-frame"><span>Photo coming soon</span></div>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="slide-nav">
          <button type="button" class="slide-arrow" id="slide-prev" aria-label="Previous project">←</button>
          <span class="label" id="slide-counter">01 / {String(projects.length).padStart(2, '0')}</span>
          <button type="button" class="slide-arrow" id="slide-next" aria-label="Next project">→</button>
        </div>
      </section>

      <!-- Screen 3: background. Master–detail: the timeline keeps its
           clean spacing; the selected entry's details render in the
           open space to the right (below the list on mobile). -->
      <section class="deck-screen" id="background">
        <div class="w-full max-w-[1100px] mx-auto px-6">
          <h2 class="text-base font-medium tracking-tight text-accent">Background</h2>
          <div class="mt-4 grid md:grid-cols-[minmax(0,560px)_1fr] gap-x-16 gap-y-8 items-start">
            <div id="bg-list">
              {background.map((b, i) => (
                <div class="bg-entry border-b border-rule">
                  <button
                    type="button"
                    class="bg-row group block w-full text-left grid sm:grid-cols-[150px_1fr] gap-x-8 gap-y-1 py-5 cursor-pointer"
                    data-idx={i}
                    aria-expanded={i === 0 ? 'true' : 'false'}
                  >
                    <span class="font-mono text-xs text-ink-faint pt-1">{b.period}</span>
                    <div>
                      <h2 class="text-lg sm:text-xl transition-colors group-hover:text-accent group-aria-expanded:text-accent">
                        {b.place}
                      </h2>
                      <p class="mt-1 text-sm text-ink-muted">{b.role}</p>
                    </div>
                  </button>
                  {/* Mobile-only inline accordion detail (desktop uses the side panel). */}
                  <div class="bg-inline-detail md:hidden" data-idx={i} hidden={i !== 0}>
                    <ul class="pb-5 space-y-2">
                      {b.bullets.map(item => (
                        <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                          <span class="text-accent shrink-0 mt-0.5">·</span>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))}
            </div>

            <div id="bg-panel" class="hidden md:block md:pt-5">
              {background.map((b, i) => (
                <div class="bg-detail" data-idx={i} hidden={i !== 0}>
                  <span class="label text-accent">{b.place}</span>
                  <ul class="mt-4 space-y-2.5">
                    {b.bullets.map(item => (
                      <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                        <span class="text-accent shrink-0 mt-0.5">·</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>

          <p class="bg-certs mt-6 md:mt-8 text-sm text-ink-muted">
            Microsoft Certified: Power Platform Developer (PL-400) ·
            A.A. Information Technology, Valencia College
          </p>

          <!-- Standalone About me: opens downward, styled apart from
               the timeline (mono label + chevron, no hairline row). -->
          <details class="disclosure group mt-6 md:mt-10" id="about">
            <summary class="inline-flex items-center gap-2.5 py-2">
              <span class="text-base font-medium tracking-tight text-accent group-hover:text-accent-hover transition-colors">About me</span>
              <svg
                class="text-accent group-hover:text-accent-hover transition-all duration-300 group-open:rotate-180"
                width="15" height="15" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M6 9l6 6 6-6" />
              </svg>
            </summary>
            <div class="disclosure-body mt-4 pb-2">
              <div class="grid sm:grid-cols-[auto_1fr] md:grid-cols-[auto_minmax(0,400px)_minmax(230px,1fr)] gap-x-8 gap-y-4 items-center">
                <!-- Collage: cruise + hogwarts stacked left (natural
                     aspect), greyhound full-height right. Click opens
                     the preview dialog. -->
                <div class="about-photos grid grid-cols-2 gap-2 w-full max-w-[340px]">
                  <div class="flex flex-col gap-2">
                    <button type="button" class="about-photo block cursor-zoom-in" aria-label="View photo larger">
                      <img src="/images/about/cruise.jpg" alt="Chris and his partner at a cruise port" width="845" height="900" loading="lazy" class="w-full h-auto rounded-lg border border-rule" />
                    </button>
                    <button type="button" class="about-photo block cursor-zoom-in" aria-label="View photo larger">
                      <img src="/images/about/hogwarts.jpg" alt="Chris and his partner at the Hogwarts Express" width="900" height="675" loading="lazy" class="w-full h-auto rounded-lg border border-rule" />
                    </button>
                  </div>
                  <button type="button" class="about-photo block cursor-zoom-in h-full" aria-label="View photo larger">
                    <img src="/images/about/greyhound.jpg" alt="Chris with his greyhound in a sweater" width="675" height="900" loading="lazy" class="w-full h-full object-cover rounded-lg border border-rule" />
                  </button>
                </div>
                <!-- TODO(chris): add anything personal you want here:
                     hobbies, interests, what you're into outside work. -->
                <div class="space-y-4">
                  <p class="text-sm text-ink leading-[1.7] font-medium">
                    My journey so far has been driven by a single question:
                    <em class="text-accent">Is there a better way to do this?</em>
                  </p>
                  <p class="text-ink-muted text-sm leading-[1.7]">
                    After transitioning from banking to project management at a Big 4 firm, I
                    experimented with Power Automate and Alteryx to build my first workflow
                    automations. Once I saw how much repetitive administrative work and scattered
                    spreadsheet chaos I was eliminating, I knew I wanted to do more.
                  </p>
                  <p class="text-ink-muted text-sm leading-[1.7]">
                    So when a small business offered me the opportunity to architect and deploy
                    solutions from the ground up, I took it. Having built and implemented my own
                    systems proved that the right optimizations don't just save time, they help
                    measurably move a business forward.
                  </p>
                </div>
                <!-- TODO(chris): edit this list, these are guesses from
                     the photos; swap in whatever is actually true. -->
                <div class="hidden md:block">
                  <span class="label">Off the clock</span>
                  <ul class="mt-4 space-y-3">
                    <li class="text-ink-muted text-sm leading-[1.7] flex gap-3">
                      <span class="text-accent shrink-0">·</span>Vacationing when I can
                    </li>
                    <li class="text-ink-muted text-sm leading-[1.7] flex gap-3">
                      <span class="text-accent shrink-0">·</span>Taking pics of my Greyhound
                    </li>
                    <li class="text-ink-muted text-sm leading-[1.7] flex gap-3">
                      <span class="text-accent shrink-0">·</span>Re-watching movies
                    </li>
                    <li class="text-ink-muted text-sm leading-[1.7] flex gap-3">
                      <span class="text-accent shrink-0">·</span>Explaining board games
                    </li>
                    <li class="text-ink-muted text-sm leading-[1.7] flex gap-3">
                      <span class="text-accent shrink-0">·</span>Going for a hike
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </details>

          <p class="mt-10 text-ink-faint text-xs">&copy; {new Date().getFullYear()} Chris Morales</p>
        </div>
      </section>
    </div>

    <!-- Photo preview (click any About me photo; arrows/swipe/scroll to browse) -->
    <dialog id="photo-viewer" aria-label="Photo preview">
      <button type="button" class="slide-arrow shrink-0" id="pv-prev" aria-label="Previous photo">←</button>
      <div class="flex flex-col items-center gap-2 min-w-0">
        <img id="photo-viewer-img" src="" alt="" />
        <span id="pv-caption" class="pv-caption"></span>
        <span id="pv-counter" class="label pv-counter"></span>
      </div>
      <button type="button" class="slide-arrow shrink-0" id="pv-next" aria-label="Next photo">→</button>
    </dialog>

    <nav class="deck-dots" aria-label="Sections">
      {screens.map((s, i) => (
        <button type="button" class="deck-dot" data-goto={i} aria-label={s.name} aria-current={i === 0 ? 'true' : undefined}></button>
      ))}
    </nav>
  </div>

  <script>
    const deck = document.getElementById('deck')!;
    const screens = Array.from(deck.querySelectorAll<HTMLElement>('.deck-screen'));
    const slidesEl = document.getElementById('slides')!;
    const slideCount = slidesEl.children.length;
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.deck-dot'));
    const counter = document.getElementById('slide-counter')!;
    const prevBtn = document.getElementById('slide-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('slide-next') as HTMLButtonElement;
    const projectsIdx = screens.findIndex(s => s.id === 'projects');
    const viewer = document.getElementById('photo-viewer') as HTMLDialogElement;

    let screenIdx = 0;
    let slideIdx = 0;

    function render() {
      deck.style.transform = `translateY(-${screenIdx * 100}%)`;
      slidesEl.style.transform = `translateX(-${slideIdx * 100}%)`;
      dots.forEach((d, i) =>
        i === screenIdx ? d.setAttribute('aria-current', 'true') : d.removeAttribute('aria-current')
      );
      counter.textContent = `${String(slideIdx + 1).padStart(2, '0')} / ${String(slideCount).padStart(2, '0')}`;
      prevBtn.disabled = slideIdx === 0;
      nextBtn.disabled = slideIdx === slideCount - 1;
      const hash = screenIdx === 0 ? '' : `#${screens[screenIdx].id}`;
      history.replaceState(null, '', hash || location.pathname);
    }

    function goScreen(next: number) {
      screenIdx = Math.min(Math.max(next, 0), screens.length - 1);
      render();
    }

    function goSlide(next: number) {
      slideIdx = Math.min(Math.max(next, 0), slideCount - 1);
      render();
    }

    // Advance: inside the projects screen, horizontal slides consume
    // the gesture until they run out, then the deck moves on.
    function advance(dir: 1 | -1) {
      if (screenIdx === projectsIdx) {
        if (dir > 0 && slideIdx < slideCount - 1) return goSlide(slideIdx + 1);
        if (dir < 0 && slideIdx > 0) return goSlide(slideIdx - 1);
      }
      goScreen(screenIdx + dir);
    }

    // Wheel: accumulate small deltas, lock during the transition so
    // trackpad inertia doesn't skip screens.
    let acc = 0;
    let pvAcc = 0;
    let locked = false;
    window.addEventListener(
      'wheel',
      e => {
        e.preventDefault();
        if (viewer.open) {
          pvAcc += e.deltaY;
          if (Math.abs(pvAcc) >= 60) {
            showPhoto(pvIdx + (pvAcc > 0 ? 1 : -1));
            pvAcc = 0;
          }
          return;
        }
        if (locked) return;
        acc += e.deltaY;
        if (Math.abs(acc) < 30) return;
        const dir = acc > 0 ? 1 : -1;
        acc = 0;
        locked = true;
        advance(dir);
        setTimeout(() => (locked = false), 700);
      },
      { passive: false }
    );

    // Touch: horizontal swipe moves slides on the projects screen,
    // vertical swipe moves screens.
    let tx = 0, ty = 0;
    window.addEventListener('touchstart', e => {
      tx = e.touches[0].clientX;
      ty = e.touches[0].clientY;
    }, { passive: true });
    window.addEventListener('touchmove', e => {
      if (e.touches.length === 1) e.preventDefault(); // keep pinch-zoom working
    }, { passive: false });
    window.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - tx;
      const dy = e.changedTouches[0].clientY - ty;
      if (viewer.open) {
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
          showPhoto(pvIdx + (dx < 0 ? 1 : -1));
        }
        return;
      }
      if (Math.abs(dx) < 50 && Math.abs(dy) < 50) return;
      if (screenIdx === projectsIdx && Math.abs(dx) > Math.abs(dy)) {
        goSlide(slideIdx + (dx < 0 ? 1 : -1));
      } else {
        advance(dy < 0 ? 1 : -1);
      }
    }, { passive: true });

    // Keyboard (skip when focus is on an interactive element).
    window.addEventListener('keydown', e => {
      if (viewer.open) return;
      if ((e.target as HTMLElement).closest('button, a, input, textarea, select, summary')) return;
      if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') { e.preventDefault(); advance(1); }
      else if (e.key === 'ArrowUp' || e.key === 'PageUp') { e.preventDefault(); advance(-1); }
      else if (e.key === 'ArrowRight' && screenIdx === projectsIdx) goSlide(slideIdx + 1);
      else if (e.key === 'ArrowLeft' && screenIdx === projectsIdx) goSlide(slideIdx - 1);
      else if (e.key === 'Home') goScreen(0);
      else if (e.key === 'End') goScreen(screens.length - 1);
    });

    prevBtn.addEventListener('click', () => goSlide(slideIdx - 1));
    nextBtn.addEventListener('click', () => goSlide(slideIdx + 1));
    dots.forEach(d => d.addEventListener('click', () => goScreen(Number(d.dataset.goto))));

    // Deep links: /#projects, /#background, /#<project-id>.
    function jumpToHash(hash: string) {
      const id = decodeURIComponent(hash.replace('#', ''));
      if (!id) return goScreen(0);
      const screenTarget = screens.findIndex(s => s.id === id);
      if (screenTarget >= 0) return goScreen(screenTarget);
      const slideTarget = Array.from(slidesEl.children).findIndex(el => el.id === id);
      if (slideTarget >= 0) {
        slideIdx = slideTarget;
        goScreen(projectsIdx);
      }
    }

    // Background master–detail: selecting a row swaps the desktop side
    // panel (with a short fade) and, on mobile, the inline accordion
    // detail beneath the row. Only one is open at a time, so height stays
    // bounded on every screen.
    const bgRows = Array.from(document.querySelectorAll<HTMLButtonElement>('.bg-row'));
    const bgDetails = Array.from(document.querySelectorAll<HTMLElement>('.bg-detail'));
    const bgInline = Array.from(document.querySelectorAll<HTMLElement>('.bg-inline-detail'));
    bgRows.forEach(row => row.addEventListener('click', () => {
      const idx = row.dataset.idx;
      bgRows.forEach(r => r.setAttribute('aria-expanded', String(r === row)));
      bgDetails.forEach(d => {
        const active = d.dataset.idx === idx;
        d.hidden = !active;
        if (active) {
          d.classList.remove('is-in');
          void d.offsetWidth; // restart the fade animation
          d.classList.add('is-in');
        }
      });
      bgInline.forEach(d => { d.hidden = d.dataset.idx !== idx; });
    }));

    // Preview gallery: click an About-me photo or any project image to
    // open the modal; browse with the arrows, ←/→, scroll wheel, or swipe
    // (wheel/touch handled in the deck listeners above). Backdrop or Esc
    // closes. The gallery list is swapped per source so each slide's
    // images (and the About collage) browse only within their own set.
    const viewerImg = document.getElementById('photo-viewer-img') as HTMLImageElement;
    const pvCounter = document.getElementById('pv-counter')!;
    const pvCaption = document.getElementById('pv-caption')!;
    const pvPrev = document.getElementById('pv-prev') as HTMLButtonElement;
    const pvNext = document.getElementById('pv-next') as HTMLButtonElement;
    type GalleryItem = { src: string; alt: string; caption?: string };
    let gallery: GalleryItem[] = [];
    let pvIdx = 0;

    function showPhoto(i: number) {
      if (gallery.length === 0) return;
      pvIdx = (i + gallery.length) % gallery.length;
      const item = gallery[pvIdx];
      viewerImg.src = item.src;
      viewerImg.alt = item.alt;
      pvCaption.textContent = item.caption || '';
      pvCaption.hidden = !item.caption;
      // Single-image galleries have nothing to browse: drop the arrows and
      // the "1 / 1" counter.
      const multi = gallery.length > 1;
      pvCounter.textContent = multi ? `${pvIdx + 1} / ${gallery.length}` : '';
      pvCounter.hidden = !multi;
      pvPrev.style.display = multi ? '' : 'none';
      pvNext.style.display = multi ? '' : 'none';
    }

    function openGallery(items: GalleryItem[], index: number) {
      if (items.length === 0) return;
      gallery = items;
      showPhoto(index);
      viewer.showModal();
    }

    const readItems = (imgs: HTMLImageElement[]): GalleryItem[] =>
      imgs.map(im => ({ src: im.src, alt: im.alt, caption: im.dataset.caption || '' }));

    // About-me photo collage.
    const aboutBtns = Array.from(document.querySelectorAll<HTMLElement>('.about-photo'));
    const aboutItems = readItems(aboutBtns.map(b => b.querySelector('img')!));
    aboutBtns.forEach((btn, i) => btn.addEventListener('click', () => openGallery(aboutItems, i)));

    // Project images: each slide's media is its own gallery. On mobile the
    // media column is hidden (slides must fit without scrolling), so a
    // "View screenshots" button opens the same gallery instead.
    document.querySelectorAll<HTMLElement>('.slide').forEach(slide => {
      const imgs = Array.from(slide.querySelectorAll<HTMLImageElement>('.slide-media img'));
      if (imgs.length === 0) return;
      const items = readItems(imgs);
      imgs.forEach((im, i) => {
        im.classList.add('zoomable');
        im.addEventListener('click', () => openGallery(items, i));
      });
      slide.querySelector('.slide-gallery-btn')?.addEventListener('click', () => openGallery(items, 0));
    });

    pvPrev.addEventListener('click', () => showPhoto(pvIdx - 1));
    pvNext.addEventListener('click', () => showPhoto(pvIdx + 1));
    viewer.addEventListener('click', e => {
      if (e.target === viewer) viewer.close(); // backdrop only
    });
    window.addEventListener('keydown', e => {
      if (!viewer.open) return;
      if (e.key === 'ArrowRight') showPhoto(pvIdx + 1);
      else if (e.key === 'ArrowLeft') showPhoto(pvIdx - 1);
    });

    // Before/after cyclers: two card stacks (before above, after below).
    // One arrow pair advances BOTH stacks in lockstep, fanning the other
    // versions behind the front card. Deliberately NOT a modal preview.
    document.querySelectorAll<HTMLElement>('.ba-cycler').forEach(cycler => {
      const stacks = Array.from(cycler.querySelectorAll<HTMLElement>('.ba-stack'));
      const count = cycler.querySelector<HTMLElement>('.ba-count');
      if (stacks.length === 0 || !count) return;
      const total = stacks[0].querySelectorAll('.ba-card').length;
      if (total === 0) return;
      let i = 0;
      const layout = () => {
        stacks.forEach(stack => {
          const cards = Array.from(stack.querySelectorAll<HTMLElement>('.ba-card'));
          cards.forEach((card, j) => {
            const d = (j - i + cards.length) % cards.length; // 0 = front
            card.style.transform = `translate(${d * 8}px, ${d * 6}px) rotate(${d * 3}deg) scale(${1 - d * 0.045})`;
            card.style.zIndex = String(cards.length - d);
            card.style.opacity = String(1 - d * 0.32);
          });
        });
        count.textContent = `${i + 1} / ${total}`;
      };
      cycler.querySelector('.ba-prev')!.addEventListener('click', () => { i = (i - 1 + total) % total; layout(); });
      cycler.querySelector('.ba-next')!.addEventListener('click', () => { i = (i + 1) % total; layout(); });
      layout();
    });

    if (location.hash) jumpToHash(location.hash);
    render();
  </script>
</BaseLayout>
