---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => data.featured))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const stack = [
  'React', 'TypeScript', 'Power Platform', 'Dataverse', 'Azure Functions',
  'Power Automate', 'Astro', 'Node.js', 'QuickBooks API', 'DocuSign API',
  'Microsoft Graph', 'Bicep', 'Vite', 'Playwright', 'Power BI',
];
---

<BaseLayout title="Home">
  <section class="relative min-h-[92vh] flex flex-col justify-center px-6 overflow-hidden">
    <div class="hero-glow top-[-10%] right-[-10%]"></div>
    <div class="max-w-[1200px] mx-auto w-full relative">
      <p class="hero-fade label flex items-center gap-2.5" style="--d: 0.05s">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-60"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        Building at Annapurna Construction
      </p>
      <h1 class="mt-6 font-display text-[clamp(3.5rem,8vw,7rem)] leading-[0.95] tracking-tight">
        <span class="hero-mask"><span class="hero-line" style="--d: 0.15s">Chris</span></span>
        <span class="hero-mask"><span class="hero-line" style="--d: 0.28s">Morales</span></span>
      </h1>
      <p class="hero-fade mt-8 max-w-[520px] text-ink-muted text-lg leading-relaxed" style="--d: 0.5s">
        Business systems developer. I build the internal apps, integrations,
        and automations that run a commercial construction company —
        from the office to the jobsite.
      </p>
      <div class="hero-fade flex gap-7 mt-10" style="--d: 0.65s">
        <a href="/projects" class="arrow-link text-sm font-medium text-accent hover:text-accent-hover transition-colors">
          See the work <span class="arrow">→</span>
        </a>
        <a
          href="https://www.linkedin.com/in/cmorales88/"
          target="_blank"
          rel="noopener noreferrer"
          class="link-underline text-sm font-medium text-ink-muted hover:text-ink transition-colors"
        >
          LinkedIn
        </a>
        <a
          href="mailto:chrismorales5112@gmail.com"
          class="link-underline text-sm font-medium text-ink-muted hover:text-ink transition-colors"
        >
          Email
        </a>
      </div>
    </div>
    <div class="hero-fade absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3" style="--d: 1.1s">
      <span class="label text-[0.65rem]">Scroll</span>
      <span class="scroll-cue-line"></span>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="px-6 pt-24 pb-12">
      <div class="max-w-[1200px] mx-auto">
        <span class="label" data-reveal>Selected Work</span>
        <div class="mt-8">
          {projects.map((project, i) => (
            <a
              href={`/projects#${project.id}`}
              class:list={[
                'work-row arrow-link group grid grid-cols-[auto_1fr] sm:grid-cols-[3rem_1fr_auto] gap-x-6 py-10 transition-colors',
                i > 0 && 'border-t border-rule',
              ]}
              data-reveal
            >
              <span class="work-index pt-2">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h2 class="font-display text-2xl sm:text-4xl text-ink group-hover:text-accent transition-colors">
                  {project.data.title}
                  <span class="arrow inline-block text-ink-faint group-hover:text-accent">→</span>
                </h2>
                <p class="mt-3 text-ink-muted max-w-[600px]">{project.data.description}</p>
                {project.data.tech && (
                  <div class="flex flex-wrap gap-x-4 gap-y-1 mt-4">
                    {project.data.tech.map(t => (
                      <span class="text-xs font-mono text-ink-faint">{t}</span>
                    ))}
                  </div>
                )}
              </div>
              <span class="hidden sm:block text-ink-faint text-sm font-mono pt-2">
                {project.data.date.getFullYear()}–
              </span>
            </a>
          ))}
        </div>
        <a
          href="/projects"
          class="arrow-link inline-block mt-8 text-sm text-accent hover:text-accent-hover transition-colors"
          data-reveal
        >
          View all projects <span class="arrow">→</span>
        </a>
      </div>
    </section>
  )}

  <section class="py-16" data-reveal>
    <div class="marquee-wrap border-y border-rule py-5">
      <div class="marquee gap-12 pr-12">
        {[...stack, ...stack].map(item => (
          <span class="text-sm font-mono text-ink-faint whitespace-nowrap">{item}</span>
        ))}
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="px-6 py-12">
      <div class="max-w-[1200px] mx-auto">
        <span class="label" data-reveal>Recent Writing</span>
        <div class="mt-8">
          {posts.map((post, i) => (
            <a
              href={`/writing/${post.id}`}
              class:list={[
                'arrow-link block py-6 text-ink hover:text-accent transition-colors group',
                i > 0 && 'border-t border-rule',
              ]}
              data-reveal
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <h3 class="font-display text-xl sm:text-2xl group-hover:text-accent transition-colors">
                  {post.data.title} <span class="arrow inline-block text-ink-faint group-hover:text-accent">→</span>
                </h3>
                <span class="text-ink-faint text-sm font-mono shrink-0">
                  {post.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    year: 'numeric',
                  })}
                </span>
              </div>
              <p class="mt-2 text-ink-muted text-sm max-w-[600px]">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
        <a
          href="/writing"
          class="arrow-link inline-block mt-8 text-sm text-accent hover:text-accent-hover transition-colors"
          data-reveal
        >
          Read all posts <span class="arrow">→</span>
        </a>
      </div>
    </section>
  )}
</BaseLayout>
