---
import fs from 'node:fs';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Drop a photo at public/images/profile.jpg and it appears automatically.
const hasProfilePhoto = fs.existsSync(new URL('../../public/images/profile.jpg', import.meta.url));

const skills = [
  {
    group: 'Microsoft stack',
    items: [
      'Power Automate', 'Power Apps Code Apps', 'Dataverse', 'Power BI', 'Power Query',
      'SharePoint Online', 'Microsoft Teams', 'AI Builder', 'Entra ID', 'Microsoft Graph', 'MSAL',
    ],
  },
  {
    group: 'Engineering',
    items: [
      'TypeScript', 'React 19', 'Node.js', 'Vite', 'Vitest', 'Playwright',
      'Git / GitHub', 'GitHub Actions CI/CD', 'Astro',
    ],
  },
  {
    group: 'Integrations',
    items: [
      'QuickBooks Online', 'QuickBooks Time', 'DocuSign', 'CloudEvents', 'Webhooks', 'REST / OData',
    ],
  },
  {
    group: 'AI tooling',
    items: [
      'AI Builder GPT prompts', 'Document extraction', 'AI summarization & translation',
      'MCP servers', 'AI-assisted development',
    ],
  },
  {
    group: 'Practices',
    items: [
      'Decision records', 'Runbooks & postmortems', 'RBAC-as-code', 'Structured pilots',
      'Parallel-run cutovers', 'Backlog management', 'User training & SOPs',
    ],
  },
];

const experience = [
  {
    company: 'Annapurna Construction',
    role: 'Software/Systems Developer',
    period: 'Oct 2025 — Present',
    summary:
      'Building the internal platform for a commercial construction company — project management and field apps, accounting integrations, and the data architecture underneath.',
    bullets: [
      'Led a Dataverse schema migration of 39K+ records across legacy and new tables — resolving duplicate data and scaling limits while preserving every relationship',
      'Integrated QuickBooks Online, QuickBooks Time, and DocuSign to eliminate duplicate entry and create a single financial source of truth',
      'Co-built two internal workspace applications with React, TypeScript, and Power Apps Code Apps, modernizing office-to-field workflows',
      'Implemented the GitHub-based monorepo architecture: shared components, CI quality gates, documentation and governance standards',
      'Designed role-based access control spanning Entra security groups, MDM, Dataverse security roles, and app-level permissions',
    ],
  },
  {
    company: 'KPMG US',
    role: 'Senior PMO Analyst',
    period: 'Jan 2021 — Oct 2025',
    summary:
      'Program financials and reporting automation for state-government consulting engagements.',
    bullets: [
      'Managed $15M+ in engagement budgets under margin pressure, contract ceilings, and compliance requirements',
      'Automated month-end reporting pipelines with Alteryx, saving hundreds of hours of manual PMO effort',
      'Delivered $239K+ in cost savings through resource optimization across engagements',
      'Facilitated cross-functional project meetings and trained junior staff',
    ],
  },
  {
    company: 'Westgate Resorts',
    role: 'Administrative Assistant',
    period: 'Aug 2017 — Jan 2021',
    summary: 'Operational analytics and reporting for resort operations.',
    bullets: [
      'Produced operational analytics with Excel, SQL, and Tableau to improve productivity and leadership visibility',
      'Streamlined reporting processes and strengthened documentation and training programs',
    ],
  },
];
---

<BaseLayout title="Home">
  <!-- Hero + About, merged -->
  <section id="top" class="relative pt-36 pb-20 px-6 overflow-hidden">
    <div class="hero-glow top-[-20%] right-[-15%]"></div>
    <div class="max-w-[1200px] mx-auto relative">
      <div class="grid md:grid-cols-[1fr_auto] gap-12 md:gap-16 items-start">
        <div class="max-w-[640px]">
          <p class="hero-fade label flex items-center gap-2.5" style="--d: 0.05s">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-60"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
            </span>
            Open to opportunities · Orlando, FL
          </p>
          <h1 class="mt-6 text-[clamp(2.75rem,6vw,4.5rem)] leading-[1.02] tracking-tight">
            <span class="hero-mask"><span class="hero-line" style="--d: 0.15s">Chris Morales</span></span>
          </h1>
          <p class="hero-fade mt-3 text-xl text-accent font-medium" style="--d: 0.3s">
            Business Systems Developer
          </p>

          <div class="hero-fade mt-8 space-y-5 text-ink-muted leading-relaxed" style="--d: 0.45s">
            <p>
              I build the software that runs a commercial construction company —
              the project management platform in the office, the field apps on
              jobsite iPads, and the integrations that keep accounting,
              contracts, and payroll in sync.
            </p>
            <p>
              Construction doesn't forgive flaky software. Superintendents work
              from spotty jobsite connections, billing has to reconcile to the
              penny against QuickBooks, and a contract can't go out with the
              wrong scope attached. So I spend my time on offline-resilient
              write queues, idempotent accounting syncs, and document pipelines —
              React and TypeScript on Microsoft's Power Platform.
            </p>
            <p>
              I got here through operations, not a CS degree: operational
              analytics at Westgate Resorts, then program finances as a Senior
              PMO Analyst at KPMG — where automating my own reporting
              bottlenecks taught me that the highest-leverage code removes work
              someone dreads doing. I'm a Microsoft Certified Power Platform
              Developer (PL-400).
            </p>
          </div>

          <div class="hero-fade mt-8 flex flex-wrap gap-7" style="--d: 0.6s">
            <a
              href="mailto:chrismorales5112@gmail.com"
              class="link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors"
            >
              Email
            </a>
            <a
              href="https://www.linkedin.com/in/cmorales88/"
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors"
            >
              LinkedIn
            </a>
            <a
              href="/resume"
              class="link-underline text-sm font-medium text-ink-muted hover:text-ink transition-colors"
            >
              Resume
            </a>
          </div>
        </div>

        <div class="hero-fade md:order-last order-first mx-auto md:mx-0" style="--d: 0.35s">
          {hasProfilePhoto ? (
            <img
              src="/images/profile.jpg"
              alt="Chris Morales"
              width="280"
              height="336"
              class="w-[220px] md:w-[280px] aspect-[5/6] object-cover rounded-2xl border border-rule"
            />
          ) : (
            <div class="w-[220px] md:w-[280px] aspect-[5/6] rounded-2xl bg-paper-alt border border-rule flex items-center justify-center">
              <span class="font-mono text-xs tracking-[0.15em] uppercase text-ink-faint">Photo</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Skills / software inventory -->
  <section id="skills" class="px-6 pb-20 scroll-mt-24">
    <div class="max-w-[1200px] mx-auto">
      <div class="section-head" data-reveal>
        <h2 class="label text-ink">Skills</h2>
        <span class="label">Software inventory</span>
      </div>
      <div class="mt-8 space-y-8">
        {skills.map(s => (
          <div class="grid sm:grid-cols-[180px_1fr] gap-x-8 gap-y-2" data-reveal>
            <p class="text-sm font-medium text-ink pt-1">{s.group}</p>
            <div class="flex flex-wrap gap-2">
              {s.items.map(item => (
                <span class="pill">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="px-6 pb-20 scroll-mt-24">
    <div class="max-w-[1200px] mx-auto">
      <div class="section-head" data-reveal>
        <h2 class="label text-ink">Experience</h2>
        <span class="label">2017 —</span>
      </div>

      <div>
        {experience.map(job => (
          <div class="py-8 border-b border-rule" data-reveal>
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-3">
                <h3 class="text-lg font-medium tracking-tight">{job.company}</h3>
                <span class="text-sm text-accent">{job.role}</span>
              </div>
              <span class="font-mono text-xs text-ink-faint shrink-0">{job.period}</span>
            </div>
            <p class="mt-2 text-sm text-ink-muted max-w-[720px]">{job.summary}</p>
            <ul class="mt-4 space-y-2.5 max-w-[720px]">
              {job.bullets.map(b => (
                <li class="text-ink-muted text-sm leading-relaxed flex gap-3">
                  <span class="text-accent shrink-0 mt-0.5">—</span>
                  {b}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-8 grid sm:grid-cols-[180px_1fr] gap-x-8 gap-y-2" data-reveal>
        <p class="label pt-1">Certifications &amp; Education</p>
        <div class="space-y-1.5 text-sm text-ink-muted">
          <p>
            <span class="text-ink font-medium">Microsoft Certified: Power Platform Developer Associate (PL-400)</span>
          </p>
          <p>A.A. in Information Technology — Valencia College, 2020</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects, expanded -->
  <section id="projects" class="px-6 pb-20 scroll-mt-24">
    <div class="max-w-[1200px] mx-auto">
      <div class="section-head" data-reveal>
        <h2 class="label text-ink">Projects</h2>
        <span class="label">{String(projects.length).padStart(2, '0')}</span>
      </div>
      <p class="mt-6 text-ink-muted text-sm max-w-[560px]" data-reveal>
        Internal software for a construction business — most of it lives in a
        private monorepo, so it's described rather than linked.
      </p>

      <div class="mt-4">
        {await Promise.all(projects.map(async (project, i) => {
          const { Content } = await render(project);
          const images = project.data.images;
          return (
            <article
              id={project.id}
              class:list={['py-12 scroll-mt-24', i > 0 && 'border-t border-rule']}
              data-reveal
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <h3 class="text-xl sm:text-2xl">{project.data.title}</h3>
                <span class="text-ink-faint text-sm font-mono shrink-0">
                  {project.data.date.getUTCFullYear()}–
                </span>
              </div>
              {project.data.kicker && (
                <span class="label text-accent text-[0.65rem]">{project.data.kicker}</span>
              )}
              <p class="mt-2 text-ink-muted text-sm max-w-[640px]">
                {project.data.description}
              </p>

              {project.data.tech && (
                <div class="flex flex-wrap gap-2 mt-5">
                  {project.data.tech.map(t => (
                    <span class="pill">{t}</span>
                  ))}
                </div>
              )}

              <div class="prose text-sm mt-6">
                <Content />
              </div>

              {images === undefined ? (
                <div class="mt-8">
                  <span class="label">In pictures</span>
                  <div class="gallery mt-3 max-w-[720px]">
                    <div class="photo-frame"><span>Photo coming soon</span></div>
                    <div class="photo-frame"><span>Photo coming soon</span></div>
                  </div>
                </div>
              ) : images.length > 0 ? (
                <div class="mt-8">
                  <span class="label">In pictures</span>
                  <div class="gallery mt-3 max-w-[720px]">
                    {images.map(img => (
                      <figure>
                        <img src={img.src} alt={img.alt} loading="lazy" />
                        {img.caption && (
                          <figcaption class="mt-2 text-xs font-mono text-ink-faint">{img.caption}</figcaption>
                        )}
                      </figure>
                    ))}
                  </div>
                </div>
              ) : null}

              {(project.data.url || project.data.github) && (
                <div class="flex gap-4 mt-8">
                  {project.data.url && (
                    <a
                      href={project.data.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="arrow-link text-sm text-accent hover:text-accent-hover transition-colors"
                    >
                      Visit <span class="arrow">→</span>
                    </a>
                  )}
                  {project.data.github && (
                    <a
                      href={project.data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="arrow-link text-sm text-accent hover:text-accent-hover transition-colors"
                    >
                      Source <span class="arrow">→</span>
                    </a>
                  )}
                </div>
              )}
            </article>
          );
        }))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="px-6 pb-8 scroll-mt-24">
    <div class="max-w-[1200px] mx-auto">
      <div class="section-head" data-reveal>
        <h2 class="label text-ink">Contact</h2>
      </div>
      <div class="mt-8 max-w-[640px]" data-reveal>
        <p class="text-ink-muted leading-relaxed">
          The fastest way to reach me is email. I'm open to conversations about
          internal tools, integrations, and operations software.
        </p>
        <div class="mt-6 flex flex-wrap gap-7">
          <a
            href="mailto:chrismorales5112@gmail.com"
            class="link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors"
          >
            chrismorales5112@gmail.com
          </a>
          <a
            href="https://www.linkedin.com/in/cmorales88/"
            target="_blank"
            rel="noopener noreferrer"
            class="link-underline text-sm font-medium text-accent hover:text-accent-hover transition-colors"
          >
            linkedin.com/in/cmorales88
          </a>
          <a
            href="/resume/Christopher-Morales-Resume.pdf"
            class="link-underline text-sm font-medium text-ink-muted hover:text-ink transition-colors"
            download
          >
            Download resume
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
