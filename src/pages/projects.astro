---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout title="Projects" description="Selected projects and work by Chris Morales.">
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-[1200px] mx-auto">
      <span class="label">Projects</span>
      <h1 class="font-display text-4xl sm:text-5xl mt-4 mb-16">
        Things I've built
      </h1>

      <div>
        {await Promise.all(projects.map(async (project, i) => {
          const { Content } = await render(project);
          return (
            <article
              id={project.id}
              class:list={['py-12', i > 0 && 'border-t border-rule']}
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 mb-4">
                <h2 class="font-display text-3xl sm:text-4xl">{project.data.title}</h2>
                <span class="text-ink-faint text-sm font-mono shrink-0">
                  {project.data.date.getFullYear()}–
                </span>
              </div>

              <p class="text-ink-muted text-lg max-w-[640px] mb-6">
                {project.data.description}
              </p>

              {project.data.tech && (
                <div class="flex flex-wrap gap-x-4 gap-y-1 mb-6">
                  {project.data.tech.map(t => (
                    <span class="text-xs font-mono text-ink-faint">{t}</span>
                  ))}
                </div>
              )}

              <div class="prose">
                <Content />
              </div>

              <div class="flex gap-4 mt-6">
                {project.data.url && (
                  <a
                    href={project.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-accent hover:text-accent-hover transition-colors"
                  >
                    Visit →
                  </a>
                )}
                {project.data.github && (
                  <a
                    href={project.data.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-accent hover:text-accent-hover transition-colors"
                  >
                    Source →
                  </a>
                )}
              </div>
            </article>
          );
        }))}
      </div>
    </div>
  </section>
</BaseLayout>
