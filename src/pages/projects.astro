---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout title="Projects" description="Systems built by Chris Morales — internal platforms, field software, and integrations.">
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-[1200px] mx-auto">
      <span class="label" data-reveal>Projects</span>
      <h1 class="font-serif font-normal text-4xl sm:text-6xl mt-4 mb-6" data-reveal>
        Systems I've <em class="text-accent">built</em>
      </h1>
      <p class="text-ink-muted max-w-[560px] mb-14" data-reveal>
        Internal software for a construction business — most of it lives
        in a private monorepo, so it's described rather than linked.
        Open any entry for the full story.
      </p>

      <div>
        {await Promise.all(projects.map(async (project, i) => {
          const { Content } = await render(project);
          const images = project.data.images;
          return (
            <details
              id={project.id}
              class:list={['disclosure group scroll-mt-24', i > 0 && 'border-t border-rule']}
              data-reveal
            >
              <summary class="py-8 flex items-start gap-6">
                <span class="work-index pt-2 hidden sm:block">{String(i + 1).padStart(2, '0')}</span>
                <div class="flex-1">
                  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                    <h2 class="text-xl sm:text-2xl group-hover:text-accent transition-colors">
                      {project.data.title}
                    </h2>
                    <span class="text-ink-faint text-sm font-mono shrink-0">
                      {project.data.date.getUTCFullYear()}–
                    </span>
                  </div>
                  {project.data.kicker && (
                    <span class="label text-accent text-[0.65rem]">{project.data.kicker}</span>
                  )}
                  <p class="mt-2 text-ink-muted text-sm max-w-[600px]">
                    {project.data.description}
                  </p>
                </div>
                <span class="disc-icon mt-2 text-ink-muted"></span>
              </summary>

              <div class="disclosure-body pb-12 sm:pl-[calc(3rem+0.5rem)]">
                {project.data.tech && (
                  <div class="flex flex-wrap gap-x-4 gap-y-1 mb-6">
                    {project.data.tech.map(t => (
                      <span class="text-xs font-mono text-ink-faint">{t}</span>
                    ))}
                  </div>
                )}

                <div class="prose text-sm">
                  <Content />
                </div>

                {images === undefined ? (
                  <div class="mt-8">
                    <span class="label">In pictures</span>
                    <div class="gallery mt-3 max-w-[720px]">
                      <div class="photo-frame"><span>Photo coming soon</span></div>
                      <div class="photo-frame"><span>Photo coming soon</span></div>
                    </div>
                  </div>
                ) : images.length > 0 ? (
                  <div class="mt-8">
                    <span class="label">In pictures</span>
                    <div class="gallery mt-3 max-w-[720px]">
                      {images.map(img => (
                        <figure>
                          <img src={img.src} alt={img.alt} loading="lazy" />
                          {img.caption && (
                            <figcaption class="mt-2 text-xs font-mono text-ink-faint">{img.caption}</figcaption>
                          )}
                        </figure>
                      ))}
                    </div>
                  </div>
                ) : null}

                {(project.data.url || project.data.github) && (
                  <div class="flex gap-4 mt-8">
                    {project.data.url && (
                      <a
                        href={project.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="arrow-link text-sm text-accent hover:text-accent-hover transition-colors"
                      >
                        Visit <span class="arrow">→</span>
                      </a>
                    )}
                    {project.data.github && (
                      <a
                        href={project.data.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="arrow-link text-sm text-accent hover:text-accent-hover transition-colors"
                      >
                        Source <span class="arrow">→</span>
                      </a>
                    )}
                  </div>
                )}
              </div>
            </details>
          );
        }))}
      </div>
    </div>
  </section>

  <script>
    // Deep links (#project-id) should open the target disclosure.
    function openFromHash() {
      const id = decodeURIComponent(location.hash.slice(1));
      if (!id) return;
      const el = document.getElementById(id);
      if (el instanceof HTMLDetailsElement) {
        el.open = true;
        el.scrollIntoView({ block: 'start' });
      }
    }
    document.addEventListener('astro:page-load', openFromHash);
    window.addEventListener('hashchange', openFromHash);
  </script>
</BaseLayout>
