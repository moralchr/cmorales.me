---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Writing" description="Posts and notes by Chris Morales.">
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-[1200px] mx-auto">
      <span class="label">Writing</span>
      <h1 class="font-display text-4xl sm:text-5xl mt-4 mb-16">
        Posts & notes
      </h1>

      {posts.length === 0 ? (
        <p class="text-ink-muted">Nothing here yet. Check back soon.</p>
      ) : (
        <div>
          {posts.map((post, i) => (
            <a
              href={`/writing/${post.id}`}
              class:list={[
                'block py-8 group transition-colors',
                i > 0 && 'border-t border-rule',
              ]}
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
                <h2 class="font-display text-2xl sm:text-3xl text-ink group-hover:text-accent transition-colors">
                  {post.data.title}
                </h2>
                <span class="text-ink-faint text-sm font-mono shrink-0">
                  {post.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric',
                  })}
                </span>
              </div>
              <p class="mt-3 text-ink-muted max-w-[600px]">
                {post.data.description}
              </p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex gap-3 mt-3">
                  {post.data.tags.map(tag => (
                    <span class="text-xs font-mono text-ink-faint">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
