---
const pathname = Astro.url.pathname;
const links = [
  { href: '/#projects', label: 'Projects' },
  { href: '/#contact', label: 'Contact' },
  { href: '/resume', label: 'Resume' },
];
const isActive = (href: string) => !href.includes('#') && pathname.startsWith(href);
---

<header class="site-header fixed top-0 left-0 right-0 z-50 bg-paper/90 backdrop-blur-sm">
  <nav class="max-w-[1100px] mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight text-lg text-ink hover:text-ink">
      <span class="hidden sm:inline">Chris Morales</span>
      <span class="sm:hidden">CM</span>
    </a>
    <div class="flex items-center gap-5 sm:gap-8">
      {links.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class:list={[
            'link-underline label transition-colors',
            isActive(link.href) ? 'text-ink' : 'hover:text-ink',
          ]}
        >
          {link.label}
        </a>
      ))}
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="text-ink-muted hover:text-ink transition-colors cursor-pointer"
      >
        <svg class="dark:hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.5" />
          <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8" />
        </svg>
        <svg class="hidden dark:block" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  document.addEventListener('click', e => {
    if ((e.target as HTMLElement).closest('#theme-toggle')) {
      const dark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', dark ? 'dark' : 'light');
    }
  });
</script>
