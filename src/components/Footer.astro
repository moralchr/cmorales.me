---
const year = new Date().getFullYear();
---

<footer class="border-t border-rule mt-24">
  <div class="max-w-[1200px] mx-auto px-6 py-16">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div>
        <p class="font-display text-lg">Chris Morales</p>
        <p class="text-ink-muted text-sm mt-1">Software Engineer · Orlando, FL</p>
      </div>
      <div class="flex gap-6">
        <a
          href="https://github.com/moralchr"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-ink-muted hover:text-ink transition-colors"
        >
          GitHub
        </a>
        <a
          href="mailto:chris@cmorales.me"
          class="text-sm text-ink-muted hover:text-ink transition-colors"
        >
          Email
        </a>
      </div>
    </div>
    <p class="text-ink-faint text-xs mt-8">&copy; {year} Chris Morales</p>
  </div>
</footer>
