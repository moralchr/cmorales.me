---
const year = new Date().getFullYear();
const socials = [
  { href: 'https://www.linkedin.com/in/cmorales88/', label: 'LinkedIn' },
  { href: 'mailto:chrismorales5112@gmail.com', label: 'Email' },
];
---

<footer class="border-t border-rule mt-24">
  <div class="max-w-[1200px] mx-auto px-6 pt-20 pb-16">
    <div data-reveal>
      <span class="label px-0">Contact</span>
      <a
        href="mailto:chrismorales5112@gmail.com"
        class="big-cta block mt-6 -mx-6 text-ink hover:text-accent transition-colors"
        aria-label="Email Chris Morales"
      >
        <div class="marquee-wrap">
          <div class="marquee-slow items-baseline gap-10 pr-10 font-display text-[clamp(3.5rem,9vw,7.5rem)] leading-none whitespace-nowrap">
            {Array.from({ length: 4 }).map(() => (
              <>
                <span>Let's talk</span>
                <span class="text-accent italic" aria-hidden="true">→</span>
              </>
            ))}
          </div>
        </div>
      </a>
      <p class="mt-8 text-ink-muted max-w-[480px] px-0">
        Open to interesting problems in internal tools, integrations,
        and operations software.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mt-20 pt-8 border-t border-rule">
      <div>
        <p class="font-display text-lg">Chris Morales</p>
        <p class="text-ink-muted text-sm mt-1">Business Systems Developer · Orlando, FL</p>
      </div>
      <div class="flex gap-6">
        {socials.map(s => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="link-underline text-sm text-ink-muted hover:text-ink transition-colors"
          >
            {s.label}
          </a>
        ))}
      </div>
    </div>
    <p class="text-ink-faint text-xs mt-8">&copy; {year} Chris Morales · Built with Astro</p>
  </div>
</footer>
