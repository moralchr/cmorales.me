---
// Soft launch gate. Client-side only — keeps casual visitors out, not a
// security boundary. Remove by setting GATED = false in BaseLayout.
---

<div id="gate" class="gate" data-gate>
  <div class="gate-inner px-6">
    <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 pb-4 border-b border-ink">
      <span class="label text-ink">cmorales.me</span>
      <span class="label">Sheet CM-000</span>
    </div>
    <h1 class="mt-8 text-[clamp(2.25rem,6vw,4.5rem)] leading-[1.05] tracking-[-0.02em]">
      Under construction.
    </h1>
    <p class="mt-6 text-ink-muted max-w-[420px]">
      Something is taking shape here. Check back shortly.
    </p>
  </div>

  <form id="gate-form" class="gate-pin" autocomplete="off">
    <label for="gate-input" class="label text-[0.65rem]">Have a pin?</label>
    <div class="gate-row">
      <input
        id="gate-input"
        type="password"
        inputmode="numeric"
        maxlength="8"
        placeholder="····"
        aria-label="Enter access pin"
      />
      <button type="submit" aria-label="Submit pin">→</button>
    </div>
  </form>
</div>

<style>
  .gate {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s var(--ease-out-expo), visibility 0.6s;
  }

  .gate.gate-open {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .gate-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }

  .gate-pin {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-end;
  }

  .gate-row {
    display: flex;
    gap: 0.4rem;
  }

  .gate-pin input {
    width: 7rem;
    padding: 0.4rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-align: center;
    color: var(--color-ink);
    background: var(--color-paper-alt);
    border: 1px solid var(--color-rule);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .gate-pin input:focus {
    border-color: var(--color-accent);
  }

  /* Mobile numeric keyboards have no return key — the form needs a real
     submit button. */
  .gate-pin button {
    padding: 0.4rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    background: var(--color-paper-alt);
    border: 1px solid var(--color-rule);
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .gate-pin button:hover,
  .gate-pin button:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .gate-pin input.shake {
    animation: gate-shake 0.4s ease;
    border-color: var(--color-accent);
  }

  @keyframes gate-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    50% { transform: translateX(5px); }
    75% { transform: translateX(-3px); }
  }

  /* Content behind the gate stays unscrollable while locked. */
  :global(html.gated) {
    overflow: hidden;
  }

  /* Pre-paint guard: returning unlocked visitors never see the gate. */
  :global(html.unlocked) .gate {
    display: none;
  }
</style>

<script>
  const KEY = 'site-unlocked';
  const HASH = '14326baf59373fee76fa43e4599bccab8aca306b19090abb32d50d09a5ab47f8';

  async function sha256(text: string): Promise<string> {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(text));
    return Array.from(new Uint8Array(buf))
      .map(b => b.toString(16).padStart(2, '0'))
      .join('');
  }

  function apply() {
    const gate = document.getElementById('gate');
    if (!gate) return;
    const unlocked = localStorage.getItem(KEY) === '1';
    gate.classList.toggle('gate-open', unlocked);
    document.documentElement.classList.toggle('gated', !unlocked);
  }

  document.addEventListener('astro:page-load', apply);
  document.addEventListener('astro:after-swap', apply);

  document.addEventListener('submit', async e => {
    const form = e.target as HTMLElement;
    if (form.id !== 'gate-form') return;
    e.preventDefault();
    const input = document.getElementById('gate-input') as HTMLInputElement | null;
    if (!input) return;
    if ((await sha256(input.value.trim())) === HASH) {
      localStorage.setItem(KEY, '1');
      apply();
    } else {
      input.value = '';
      input.classList.remove('shake');
      void input.offsetWidth;
      input.classList.add('shake');
    }
  });
</script>
