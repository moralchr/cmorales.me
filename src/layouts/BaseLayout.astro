---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ComingSoon from '../components/ComingSoon.astro';
import '../styles/global.css';

// Soft-launch gate: flip to false to open the site (also drops noindex).
const GATED = true;

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Chris Morales — Business systems developer building internal tools and integrations for construction.' } = Astro.props;
const pageTitle = title === 'Home' ? 'Chris Morales' : `${title} — Chris Morales`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {GATED && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <script is:inline>
      // Theme + JS detection, before first paint to avoid flash.
      (function () {
        const root = document.documentElement;
        root.classList.add('js');
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        root.classList.toggle('dark', dark);
        if (localStorage.getItem('site-unlocked') === '1') root.classList.add('unlocked');
      })();

      // ClientRouter swaps <html>, so re-apply on every navigation.
      document.addEventListener('astro:after-swap', () => {
        const root = document.documentElement;
        root.classList.add('js');
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        root.classList.toggle('dark', dark);
      });
    </script>
  </head>
  <body>
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>
    {GATED && <ComingSoon />}
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      function initReveals() {
        const elements = document.querySelectorAll<HTMLElement>('[data-reveal]:not(.revealed)');
        if (!('IntersectionObserver' in window)) {
          elements.forEach(el => el.classList.add('revealed'));
          return;
        }
        const observer = new IntersectionObserver(
          entries => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        elements.forEach(el => {
          // Stagger siblings that share a parent.
          const siblings = el.parentElement
            ? Array.from(el.parentElement.children).filter(c => c.hasAttribute('data-reveal'))
            : [el];
          const index = siblings.indexOf(el);
          if (index > 0) el.style.setProperty('--reveal-delay', `${Math.min(index * 0.08, 0.4)}s`);
          observer.observe(el);
        });
      }

      document.addEventListener('astro:page-load', initReveals);
    </script>

    <script>
      // Cursor follower, magnetic hovers, hero parallax. Desktop pointers only.
      const fine = window.matchMedia('(pointer: fine)').matches;
      const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (fine && !noMotion) {
        let dot: HTMLElement | null = null;
        let ring: HTMLElement | null = null;
        const grab = () => {
          dot = document.querySelector('.cursor-dot');
          ring = document.querySelector('.cursor-ring');
        };
        grab();
        document.addEventListener('astro:after-swap', grab);

        let mx = -100, my = -100, rx = -100, ry = -100;
        let seen = false;

        document.addEventListener('pointermove', e => {
          mx = e.clientX;
          my = e.clientY;
          if (!seen) {
            seen = true;
            if (dot) dot.style.opacity = '1';
            if (ring) ring.style.opacity = '1';
          }
        });

        const loop = () => {
          rx += (mx - rx) * 0.16;
          ry += (my - ry) * 0.16;
          if (dot) dot.style.transform = `translate(${mx - 3}px, ${my - 3}px)`;
          if (ring) {
            const half = ring.offsetWidth / 2;
            ring.style.transform = `translate(${rx - half}px, ${ry - half}px)`;
          }
          requestAnimationFrame(loop);
        };
        requestAnimationFrame(loop);

        // Ring grows over anything interactive.
        document.addEventListener('pointerover', e => {
          const hot = (e.target as HTMLElement).closest('a, button, summary');
          ring?.classList.toggle('is-active', !!hot);
        });

        // Magnetic pull on .magnetic elements.
        let magnet: HTMLElement | null = null;
        document.addEventListener('pointermove', e => {
          const el = (e.target as HTMLElement).closest<HTMLElement>('.magnetic');
          if (el) {
            magnet = el;
            const r = el.getBoundingClientRect();
            const dx = e.clientX - (r.left + r.width / 2);
            const dy = e.clientY - (r.top + r.height / 2);
            el.style.transform = `translate(${dx * 0.18}px, ${dy * 0.28}px)`;
          } else if (magnet) {
            magnet.style.transform = '';
            magnet = null;
          }
        });

        // Parallax: [data-parallax="0.2"] drifts at that fraction of scroll.
        let ticking = false;
        window.addEventListener(
          'scroll',
          () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
              document.querySelectorAll<HTMLElement>('[data-parallax]').forEach(el => {
                const speed = parseFloat(el.dataset.parallax || '0.2');
                el.style.translate = `0 ${window.scrollY * speed}px`;
              });
              ticking = false;
            });
          },
          { passive: true }
        );
      }
    </script>
  </body>
</html>
