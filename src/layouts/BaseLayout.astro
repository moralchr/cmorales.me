---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Chris Morales — business systems developer in Orlando, FL.' } = Astro.props;
const pageTitle = title === 'Home' ? 'Chris Morales | Systems Developer' : `${title} — Chris Morales`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const onResume = Astro.url.pathname.startsWith('/resume');
// The deck's intro screen carries its own Resume link + theme toggle,
// so the home page gets no corner controls at all.
const showCorner = Astro.url.pathname !== '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wdth,wght@0,62..125,100..900;1,62..125,100..900&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // Theme + JS detection, before first paint to avoid flash.
      (function () {
        const root = document.documentElement;
        root.classList.add('js');
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        root.classList.toggle('dark', dark);
      })();
    </script>
  </head>
  <body>
    <!-- No header bar: just quiet fixed corner controls (not on home —
         the intro screen has its own). -->
    {showCorner && (
    <div class="fixed top-5 right-6 z-50 flex items-center gap-6">
      <a
        href={onResume ? '/' : '/resume'}
        class="link-underline label hover:text-ink transition-colors"
      >
        {onResume ? 'Home' : 'Resume'}
      </a>
      <button
        data-theme-toggle
        type="button"
        aria-label="Toggle dark mode"
        class="text-ink-muted hover:text-ink transition-colors cursor-pointer"
      >
        <svg class="dark:hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.5" />
          <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8" />
        </svg>
        <svg class="hidden dark:block" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
        </svg>
      </button>
    </div>
    )}

    <main>
      <slot />
    </main>

    <script>
      // Theme switch as a view-transition crossfade where supported,
      // instant otherwise.
      const applyTheme = () => {
        const dark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', dark ? 'dark' : 'light');
      };
      document.addEventListener('click', e => {
        if (!(e.target as HTMLElement).closest('[data-theme-toggle]')) return;
        if (document.startViewTransition) document.startViewTransition(applyTheme);
        else applyTheme();
      });
    </script>
  </body>
</html>
