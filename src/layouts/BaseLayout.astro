---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ComingSoon from '../components/ComingSoon.astro';
import '../styles/global.css';

// Soft-launch gate: flip to false to open the site (also drops noindex).
const GATED = true;

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Chris Morales — Business systems developer building internal tools and integrations for construction.' } = Astro.props;
const pageTitle = title === 'Home' ? 'Chris Morales' : `${title} — Chris Morales`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {GATED && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wdth,wght@0,62..125,100..900;1,62..125,100..900&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <script is:inline>
      // Theme + JS detection, before first paint to avoid flash.
      (function () {
        const root = document.documentElement;
        root.classList.add('js');
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        root.classList.toggle('dark', dark);
        if (localStorage.getItem('site-unlocked') === '1') root.classList.add('unlocked');
      })();

      // ClientRouter swaps <html>, so re-apply on every navigation.
      document.addEventListener('astro:after-swap', () => {
        const root = document.documentElement;
        root.classList.add('js');
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        root.classList.toggle('dark', dark);
      });
    </script>
  </head>
  <body>
    {GATED && <ComingSoon />}
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      function initReveals() {
        const elements = document.querySelectorAll<HTMLElement>('[data-reveal]:not(.revealed)');
        if (!('IntersectionObserver' in window)) {
          elements.forEach(el => el.classList.add('revealed'));
          return;
        }
        const observer = new IntersectionObserver(
          entries => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        elements.forEach(el => {
          // Stagger siblings that share a parent.
          const siblings = el.parentElement
            ? Array.from(el.parentElement.children).filter(c => c.hasAttribute('data-reveal'))
            : [el];
          const index = siblings.indexOf(el);
          if (index > 0) el.style.setProperty('--reveal-delay', `${Math.min(index * 0.08, 0.4)}s`);
          observer.observe(el);
        });
      }

      document.addEventListener('astro:page-load', initReveals);
    </script>
  </body>
</html>
